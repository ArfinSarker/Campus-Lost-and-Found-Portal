<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.App.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivItemImage"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_package"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.App.MediumComponent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvItemTitle"
                    style="@style/TextAppearance.App.SectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/tvItemTypeContainer"
                    android:ellipsize="end"
                    android:maxLines="1"
                    tools:text="Black Wallet" />

                <LinearLayout
                    android:id="@+id/tvItemTypeContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvReportId"
                        style="@style/TextAppearance.App.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/bg_status_badge_found"
                        android:backgroundTint="@color/primaryDarkColor"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        tools:text="L1" />

                    <TextView
                        android:id="@+id/tvItemType"
                        style="@style/TextAppearance.App.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_status_badge_lost"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        tools:text="LOST"
                        tools:textColor="@color/statusLost" />

                </LinearLayout>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_map_pin"
                    app:tint="@color/textSecondary"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tvItemLocation"
                    style="@style/TextAppearance.App.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    tools:text="Found near Library" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/textHint"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tvItemDate"
                    style="@style/TextAppearance.App.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textSize="11sp"
                    tools:text="2 March 2026" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnViewDetails"
                style="@style/TextAppearance.App.Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:text="@string/btn_view_details"
                android:textColor="@color/primaryColor"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
