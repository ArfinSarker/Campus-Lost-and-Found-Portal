<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primaryLightColor</item>
        <item name="colorOnPrimaryContainer">@color/primaryDarkColor</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accentColor</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Navigation Drawer Selected Item Background -->
        <item name="colorSecondaryContainer">@color/primaryLightColor</item>
        <item name="colorOnSecondaryContainer">@color/primaryColor</item>

        <!-- Background and surface -->
        <item name="android:windowBackground">@color/backgroundColor</item>
        <item name="colorSurface">@color/surfaceColor</item>
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="colorOnSurfaceVariant">@color/textSecondary</item>

        <!-- Status bar color - Telegram X Style -->
        <item name="android:statusBarColor">@color/primaryDarkColor</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowTranslucentStatus">false</item>

        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Component Styles -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="materialCardViewStyle">@style/Widget.App.Card</item>

        <!-- Shape appearance -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.App.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.App.MediumComponent</item>

        <!-- Use materialTimePickerTheme for styling the MaterialTimePicker -->
        <item name="materialTimePickerTheme">@style/ThemeOverlay.App.TimePicker</item>

        <!-- Use materialCalendarTheme for styling the MaterialDatePicker -->
        <item name="materialCalendarTheme">@style/ThemeOverlay.App.DatePicker</item>
    </style>

    <!-- Theme Overlay for TimePicker to achieve the requested look -->
    <style name="ThemeOverlay.App.TimePicker" parent="ThemeOverlay.Material3.MaterialTimePicker">
        <!-- Main dialog and Header background (Dark as per screenshot) -->
        <item name="colorSurface">#323238</item>
        <item name="colorContainer">#323238</item>

        <!-- "Select Time" title text color (White) -->
        <item name="colorOnSurface">@color/white</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.App.TimePicker.Title</item>

        <!-- Hour and Minute Display (Header Chips) -->
        <!-- Selected Chip (e.g. "07") - White background, Primary color text -->
        <item name="colorPrimaryContainer">@color/white</item>
        <item name="colorOnPrimaryContainer">@color/primaryColor</item>

        <!-- Unselected Chip (e.g. "16") - Dark background, White text -->
        <item name="colorSurfaceVariant">#323238</item>
        <item name="colorOnSurfaceVariant">@color/white</item>

        <!-- Border for chips (Primary color) - This adds border around the chips -->
        <item name="colorOutline">@color/primaryColor</item>

        <!-- AM/PM Toggle -->
        <!-- Selected background (White) and text (Primary color) -->
        <item name="colorTertiaryContainer">@color/white</item>
        <item name="colorOnTertiaryContainer">@color/primaryColor</item>
        <!-- Unselected background (Transparent) and text (White) -->
        <item name="colorSecondaryContainer">@color/transparent</item>
        <item name="colorOnSecondaryContainer">@color/white</item>
        <!-- Border for AM/PM buttons -->
        <item name="colorOutlineVariant">@color/primaryColor</item>

        <!-- Analog Clock selector hand and circle -->
        <item name="colorPrimary">@color/primaryColor</item>
        <!-- Number inside selector circle -->
        <item name="colorOnPrimary">@color/black</item>

        <!-- Dial numbers styling -->
        <item name="textAppearanceLabelLarge">@style/TextAppearance.App.TimePicker.LabelBold</item>

        <item name="materialTimePickerStyle">@style/Widget.App.MaterialTimePicker</item>
    </style>

    <style name="TextAppearance.App.TimePicker.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.App.TimePicker.LabelBold" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/clock_number_color</item>
    </style>

    <style name="Widget.App.MaterialTimePicker" parent="Widget.Material3.MaterialTimePicker">
        <!-- Dial background (Dark gray) -->
        <item name="clockFaceBackgroundColor">#323238</item>
        <!-- Dial numbers color selector -->
        <item name="clockNumberTextColor">@color/clock_number_color</item>
    </style>

    <!-- Refined Theme Overlay for DatePicker for high contrast and brand consistency -->
    <style name="ThemeOverlay.App.DatePicker" parent="ThemeOverlay.Material3.MaterialCalendar">
        <!-- Header background and selected date circle (Brand Primary) -->
        <item name="colorPrimary">@color/primaryColor</item>
        <!-- Header text and selected date text (High contrast white) -->
        <item name="colorOnPrimary">@color/white</item>

        <!-- Main calendar background (White for best readability) -->
        <item name="colorSurface">@color/white</item>
        <item name="colorContainer">@color/white</item>

        <!-- Date numbers and Day labels (Dark for high contrast) -->
        <item name="colorOnSurface">@color/white</item>
        <!-- Secondary text like month navigation icons -->
        <item name="colorOnSurfaceVariant">@color/primaryLightColor</item>

        <!-- Controls like "OK" and "CANCEL" -->
        <item name="colorSecondary">@color/primaryColor</item>
    </style>

    <!-- Shape Styles -->
    <style name="ShapeAppearance.App.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">10dp</item>
    </style>

    <style name="ShapeAppearance.App.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.App.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">30dp</item>
    </style>

    <style name="ShapeAppearance.App.Circle" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.App.SmallComponent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.App.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.App.SmallComponent</item>
        <item name="strokeColor">@color/primaryColor</item>
        <item name="android:textColor">@color/primaryColor</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.App.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surfaceColor</item>
    </style>

    <!-- Typography Styles -->
    <style name="TextAppearance.App.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/textPrimary</item>
    </style>

    <style name="TextAppearance.App.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/textPrimary</item>
    </style>

    <style name="TextAppearance.App.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/textPrimary</item>
    </style>

    <style name="TextAppearance.App.Small" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/textSecondary</item>
    </style>
</resources>
